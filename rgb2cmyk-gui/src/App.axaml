<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="Rgb2CmykGui.App"
             RequestedThemeVariant="Light">
    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
    <Application.Resources>
        <FontFamily x:Key="ContentControlThemeFontFamily">avares://Avalonia.Fonts.Inter#Inter</FontFamily>
    </Application.Resources>
</Application>
